# MachineTwin Configuration

# LLM configuration.
# NVIDIA NIM usa una API compatible con OpenAI.
LLM_API_KEY=
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_TEMPERATURE=1
LLM_TOP_P=0.95
LLM_MAX_TOKENS=16384
LLM_TIMEOUT=120
LLM_MAX_RETRIES=0
LLM_ENABLE_THINKING=true
LLM_REASONING_BUDGET=16384

# Configuracion anterior (Kilo AI gateway compatible con OpenAI).
# LLM_API_KEY=
# LLM_MODEL=stepfun/step-3.7-flash:free
# LLM_BASE_URL=https://api.kilo.ai/api/gateway/
SYSTEM_PROMPT_VERSION=0.0.1
# Optional explicit prompt path. If set, it has priority over SYSTEM_PROMPT_VERSION.
SYSTEM_PROMPT_PATH=
WEB_HOST=0.0.0.0
WEB_PORT=8000

# PostgreSQL persistence for conversations, messages and traces.
POSTGRES_DB=machinetwin
POSTGRES_USER=machinetwin
POSTGRES_PASSWORD=machinetwin
POSTGRES_PORT=5433
DATABASE_URL=postgresql://machinetwin:machinetwin@localhost:5433/machinetwin
