# MachineTwin Configuration

# LLM configuration.
# El proyecto usa Kilo AI como gateway compatible con OpenAI.
# En la configuracion actual no es obligatorio definir API key.
LLM_API_KEY=
LLM_MODEL=stepfun/step-3.7-flash:free
LLM_BASE_URL=https://api.kilo.ai/api/gateway/
PROMPT_VERSION=entrega3-v1
WEB_HOST=0.0.0.0
WEB_PORT=8000

# PostgreSQL persistence for conversations, messages and traces.
POSTGRES_DB=machinetwin
POSTGRES_USER=machinetwin
POSTGRES_PASSWORD=machinetwin
POSTGRES_PORT=5432
DATABASE_URL=postgresql://machinetwin:machinetwin@localhost:5432/machinetwin
